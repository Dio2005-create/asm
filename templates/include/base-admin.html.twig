                    {% for message in app.flashes('error') %}
                        <input type="hidden" id="notice_error" value="{{ message }}" />
                    {% endfor %}
                    {% for message in app.flashes('success') %}
                        <input type="hidden" id="notice_success" value="{{ message }}" />
                    {% endfor %}
                    {% for message in app.flashes('warning') %}
                        <input type="hidden" id="notice_warning" value="{{ message }}" />
                    {% endfor %}
                    <!-- Container -->


                    <!-- Container -->

                    <div class="praticien" style="margin: 0px 25px">

                        <div class="loadBody">
                            <div class="chargement alert-dismissable alert alert-warning alert-dismissable">
                                <button aria-hidden="true" data-dismiss="alert" class="close" type="button">×</button>
                                {% trans %}Veuillez attendre...!!!{% endtrans %}
                            </div>
                        </div>

                        <div class="alert alert-danger alert-dismissable chargementError">
                            <button aria-hidden="true" data-dismiss="alert" class="close" type="button">×</button>
                            {% trans %}En attente de serveur...{% endtrans %}
                        </div>

                        <div class="modal inmodal" id="modal_create_body" role="dialog" aria-hidden="true">
                            <div class="modal-dialog modal-notify modal-primary">
                                <div class="modal-content animated bounceInDown" style="width:864px!important">
                                    <div class="create_body"></div>
                                </div>
                            </div>
                        </div>
                        {% block loader%}

                            {{ include('include/loader.html.twig') }}

                        {% endblock %}

                        {% block body %}

                        {% endblock %}
                    </div>

                    <!-- End Container  -->

                </div>
