        <style>
            .loadBody{
                display: none;
            }
            .loadBody .chargement{
                background-color: #7dc6ff;
                color: #000000;
                width: 400px;
                margin: 0 auto;
                height: 30px;
                border-radius: 5px;
                font-weight: bold;
                line-height: 30px;
                text-align: center;
                margin-top: 5px;
                position: fixed;
                z-index: 9999999;
                left: 35%;
                padding: 0;
            }
            .loadBody button.close{
                margin-right: 5px;
            }
            .chargementError{
                display: none;
                z-index: 9999999;
            }
            .badge-style {
                font-size: .8rem !important;
                font-weight: 500 !important;
                line-height: 2 !important;
                width: 82px !important;
                cursor: pointer;
            }
            table tbody tr td i {
                padding-left: 0px !important;
                cursor: pointer;
            }
            .chosen-container-multi .chosen-results {
                text-align: left;
            }
            .pagination {
        list-style: none;
        display: flex;
        justify-content: center;
        align-items: center;
        margin: 20px 0;
        padding: 0;
    }

    .pagination li {
        margin: 0 5px;
    }

    .pagination li a,
    .pagination li span {
        display: inline-block;
        padding: 8px 12px;
        border: 1px solid #ccc;
        text-decoration: none;
        color: #333;
    }

    .pagination li.active span {
        background-color: #007bff;
        color: #fff;
    }

    .pagination li.disabled span,
    .pagination li.disabled a {
        color: #aaa;
        pointer-events: none;
    }
    /* Styles for right-aligned search form */
.search-form {
    display: flex;
    justify-content: flex-end; /* Aligns items to the right */
    align-items: center;
}

.search-form input[type="text"],
.search-form button {
    margin-left: 10px;
}

.search-form input[type="text"] {
    padding: 8px;
    border: 1px solid #ccc;
    border-radius: 4px;
    font-size: 14px;
}

.search-form button {
    padding: 8px 12px;
    border: none;
    background-color: #007bff;
    color: #fff;
    border-radius: 4px;
    cursor: pointer;
    font-size: 14px;
}

/* Adjustments for responsiveness if needed */
@media screen and (max-width: 600px) {
    .search-form {
        flex-direction: column;
        justify-content: flex-start; /* Aligns items to the top for smaller screens */
        align-items: flex-end;
    }

    .search-form input[type="text"],
    .search-form button {
        margin-left: 0;
        margin-top: 10px;
    }
}

        </style>
