  {% extends 'include/base-admin.html.twig' %}
{%  block title %}
    Client
{% endblock %}
{% block stylesheets %}
    {{ parent() }}
    <style>
    /* Define your custom styles for pagination here */
    .pagination {
        list-style: none;
        display: flex;
        justify-content: center;
        align-items: center;
        margin: 20px 0;
        padding: 0;
    }

    .pagination li {
        margin: 0 5px;
    }

    .pagination li a,
    .pagination li span {
        display: inline-block;
        padding: 8px 12px;
        border: 1px solid #ccc;
        text-decoration: none;
        color: #333;
    }

    .pagination li.active span {
        background-color: #007bff;
        color: #fff;
    }

    .pagination li.disabled span,
    .pagination li.disabled a {
        color: #aaa;
        pointer-events: none;
    }
    /* Styles for right-aligned search form */
.search-form {
    display: flex;
    justify-content: flex-end; /* Aligns items to the right */
    align-items: center;
}

.search-form input[type="text"],
.search-form button {
    margin-left: 10px;
}

.search-form input[type="text"] {
    padding: 8px;
    border: 1px solid #ccc;
    border-radius: 4px;
    font-size: 14px;
}

.search-form button {
    padding: 8px 12px;
    border: none;
    background-color: #007bff;
    color: #fff;
    border-radius: 4px;
    cursor: pointer;
    font-size: 14px;
}

/* Adjustments for responsiveness if needed */
@media screen and (max-width: 600px) {
    .search-form {
        flex-direction: column;
        justify-content: flex-start; /* Aligns items to the top for smaller screens */
        align-items: flex-end;
    }

    .search-form input[type="text"],
    .search-form button {
        margin-left: 0;
        margin-top: 10px;
    }
}


</style>
{% endblock %}

{% block body %}
    <div class="modal-header text-center">
        <h5 class="modal-title white-text w-100 font-weight-bold py-2">Client</h5>

    </div>
    <div class="grid-edit-btn ">
      
          <a href="{{ path('export_audit_client') }}" class="btn btn-success">Exporter</a>
    </div>


    <div class="row-table table-content mt-3">
    <form action="{{ path('audit') }}" method="POST" class="search-form mb-2">
        <input type="text" name="search"  placeholder="Rechercher..." value="{{ search }}">
        <button type="submit">Rechercher</button>
    </form>

        <table class="table table-striped" id="example1">
            <thead>
            <tr>
                <th>Code</th>
                <th>Nom</th>
                <th>Prenoms </th>
                <th>Adresse</th>
                <th>Status</th>
                <th>Action</th>
            </tr>
            </thead>
            <tbody>
               
              
             {% for client in pagination %}     
                <tr>
                    <td>{{ client.code }}</td>
                    <td>{{ client.nom }}</td>
                    <td>{{ client.prenom }}</td>
                    <td>{{ client.adresse }}</td>
                    <td>
                        {% if client.coupure == true %}
                            <p class="badge badge-danger">Coupée</p>
                        {% else %}
                            <p class="badge badge-success">Actif</p>

                        {% endif %}
                    </td>
                    <td style="display:flex">
                        <a href="{{ path('client_audit',{'id': client.id }) }}" class="btn btn-success">Voir</a> 
                        
                    </td>                        
                </tr>
                  
             {% endfor %}
        


            </tbody>
        </table>
    </div>
    <div class="pagination">
    {{ knp_pagination_render(pagination) }}
    </div>
{% endblock %}

{% block javascripts %}

    <script>
       
        
    </script>
{% endblock %}