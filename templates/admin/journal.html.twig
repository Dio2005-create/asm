  {% extends 'include/base-admin.html.twig' %}
{%  block title %}
    Journal de caisse
{% endblock %}
{% block stylesheets %}
    {{ parent() }}
     <style>
     #day {
        display: none;
     }
     .pagination {
        list-style: none;
        display: flex;
        justify-content: center;
        align-items: center;
        margin: 20px 0;
        padding: 0;
    }

    .pagination li {
        margin: 0 5px;
    }

    .pagination li a,
    .pagination li span {
        display: inline-block;
        padding: 8px 12px;
        border: 1px solid #ccc;
        text-decoration: none;
        color: #333;
    }

    .pagination li.active span {
        background-color: #007bff;
        color: #fff;
    }

    .pagination li.disabled span,
    .pagination li.disabled a {
        color: #aaa;
        pointer-events: none;
    }
    </style>
{% endblock %}

{% block body %}
    <div class="modal-header text-center">
        <h5 class="modal-title white-text w-100 font-weight-bold py-2">Journal de Caisse</h5>

    </div>
   <form method="post" id="year-form">
      <label for="journal_type">Type de journal :</label>
        <select name="journal_type" id="journal_type">
         <option value="annuel">Type de journal</option>
            <option value="journalier" {%if selectJournal == "journalier"%}selected{% endif %}>Journal Journalier</option>
            <option value="mensuel" {%if selectJournal == "mensuel"%}selected{% endif %}>Journal Mensuel</option>
       
        </select>
        <label for="year">Sélectionnez une année :</label>
        <select id="year" name="year">
            {% for year in years %}
                <option value="{{ year.year }}" {% if year.year == selectedYear %}selected{% endif %}>{{ year.year }}</option>
            {% endfor %}
        </select>
        <label for="month">Mois :</label>
        <select name="month" id="month">
            <option value="">Tous les mois</option>
            {% for month in months %}
                <option value="{{ loop.index }}" {% if loop.index == selectedMonth %}selected{% endif %}>{{ month }}</option>
            {% endfor %}
        </select>
         <label for="day">Jour :</label>
        <select id="day" name="day">
            
        </select>
        <input type="submit" value="Afficher">
    </form>

{% if releves is defined %}
<div class="col"  style="text-align:right">
{% if selectedYear != null and selectedMonth != null and selectedDay != null %}
    <a href="{{ path('generates_excel_day', {'year': selectedYear,'month': selectedMonth,'day':selectedDay}) }}" class="btn btn-primary">Exporter au format Excel</a>
{% elseif selectedYear != null and selectedMonth != null and selectedDay == null %}

    <a href="{{ path('generer_excel_mois', {'year': selectedYear,'month': selectedMonth}) }}" class="btn btn-primary">Exporter au format Excel</a>
{% else %}
    <a href="{{ path('generates_excel', {'year': selectedYear}) }}" class="btn btn-primary">Exporter au format Excel</a>

{% endif %}
    </div>
    <div class="row-table table-content mt-3">
        <table class="table table-striped" >
            <thead>
            <tr>
                  <th>Caisse</th>
                  <th>Type De Paiement</th>
                  <th>Date</th>
                  <th>Code Client</th>
                  <th>Nom Client</th>
                  <th>Prenom Client</th>
                  <th>Consommation</th>
                  <th>Mois</th>
                  <th>Montant</th>
            </tr>
            </thead>
            <tbody>
             {% set montantTotal = 0 %}
             {% for item in releves %}
                <tr>
                 {% if item is releve %}
                        <td>{{ item.comptable ? item.comptable.fullName : '' }}</td>
                        <td>{{ item.type ? item.type : '' }}</td>
                        <td>{{ item.factureDatePaiement|date('d/m/Y') }}</td>
                        <td>{{ item.client.code }}</td>
                        <td>{{ item.client.nom }}</td>
                        <td>{{ item.client.prenom }}</td>
                        <td>{{ item.Consomation }}</td>
                        <td>{{ item.dateReleve|date('m/Y') }}</td>
                        <td>
                           {% if item.limite != null %}
                                {% if item.Consomation <= item.limite %}
                                        {% set nombre1 = item.Consomation %}
                                        {% set nombre2 = item.pu %}
                                        {% set numerator = nombre1 * nombre2 %}
                                        {% set denominator = 5 %} 
                                        {% set percentage1 = (numerator * denominator) / 100 %}
                                        {% set percentage2 = (numerator * 1) / 100 %}
                                        {% set percentage3 = (numerator * 2) / 100 %}
                                        {% if nombre1 > 10 and item.pus != null  %}
                                        {% set consomation2 = (item.Consomation - 10) * item.pus  %}
                                        {% set percentage4 = (consomation2 * 20) / 100 %}

                                        {% set resultatfinale = numerator + 1000 + percentage1 + percentage2 + percentage3 + percentage3 + percentage4 %}
                                        {% else %}
                                        {% set resultatfinale = numerator + 1000 + percentage1 + percentage2 + percentage3 + percentage3 %}

                                        {% endif %}
										{% if item.client.isSpecific == true %}
											{% set resultatfinale = resultatfinale - 50000 %}
										{% endif %}
                                        {{ resultatfinale }}
                                    {% else %}
                                    {% set numerator = ((item.Consomation - item.limite) * item.pus) + (item.limite * item.pu)  %}
                                        {% set denominator = 5 %} 
                                    {% set percentage1 = (numerator * denominator) / 100 %}
                                    {% set percentage2 = (numerator * 1) / 100 %}
                                    {% set percentage3 = (numerator * 2) / 100 %}
                                    {% if item.Consomation > 10 and item.pus != null  %}
                                    {% set consomation2 = (item.Consomation - 10) * item.pus  %}
                                    {% set percentage4 = (consomation2 * 20) / 100 %}

                                    {% set resultatfinale = numerator + 1000 + percentage1 + percentage2 + percentage3 + percentage3 + percentage4 %}
                                    {% else %}
                                    {% set resultatfinale = numerator + 1000 + percentage1 + percentage2 + percentage3 + percentage3 %}
									
                                    {% endif %}
									{% if item.client.isSpecific == true %}
											{% set resultatfinale = resultatfinale - 50000 %}
										{% endif %}
                                    {{ resultatfinale }}
                                    {% endif %}
                                    {% else %}
                                      {% set nombre1 = item.Consomation %}
                                        {% set nombre2 = item.pu %}
                                        {% set numerator = nombre1 * nombre2 %}
                                        {% set denominator = 5 %} 
                                        {% set percentage1 = (numerator * denominator) / 100 %}
                                        {% set percentage2 = (numerator * 1) / 100 %}
                                        {% set percentage3 = (numerator * 2) / 100 %}
                                        {% if nombre1 > 10 and item.pus != null  %}
                                        {% set consomation2 = (item.Consomation - 10) * item.pus  %}
                                        {% set percentage4 = (consomation2 * 20) / 100 %}

                                        {% set resultatfinale = numerator + 1000 + percentage1 + percentage2 + percentage3 + percentage3 + percentage4 %}
                                        {% else %}
                                        {% set resultatfinale = numerator + 1000 + percentage1 + percentage2 + percentage3 + percentage3 %}

                                        {% endif %}
										{% if item.client.isSpecific == true %}
											{% set resultatfinale = resultatfinale - 50000 %}
										{% endif %}
                                        {{ resultatfinale }}
                                    
                        {% endif %}
                            {% set montantTotal = montantTotal + resultatfinale %}
                        </td>
                    {% elseif item is paiement %}
                        <td>{{ item.caisse.fullName }}</td>
                        <td>Tranche de paiement</td>
                        <td>{{ item.date|date('d/m/Y') }}</td>
                          <td>
						 {% if item.contrat != null %}
                           {{ item.contrat.client.code }}
                        {% endif %}
						</td>
						 <td>
						 {% if item.contrat != null %}
                           {{ item.contrat.client.nom }}
                        {% endif %}
						</td>
						  <td>
						 {% if item.contrat != null %}
                           {{ item.contrat.client.prenom }}
                        {% endif %}
						</td>
                        <td>-</td>
                        <td>{{ item.date|date('m/Y') }}</td>
                        <td>{{ item.argent }}</td>
                        {% set montantTotal = montantTotal + item.argent %}
                    {% endif %}
                </tr>
             {% endfor %}
            </tbody>
             <tfoot>
                <tr>
                    <td colspan="6"></td>
                    <td>Total :</td>
                    <td>{{ montantTotal }}</td>
                </tr>
            </tfoot>
        </table>
        <div class="pagination">
         
            {{ knp_pagination_render(releves,'', {'selectedYear': selectedYear, 'selectedMonth': selectedMonth, 'selectedDay': selectedDay, 'selectJournal': selectJournal}) }}

        </div>
    </div>
{% endif %}

{% endblock %}

{% block javascripts %}

    <script>
        $(document).ready(function () {
          
             $('#example1').DataTable();

        });
       
         document.getElementById("journal_type").addEventListener("change", toggleDaySelector);
   
      function toggleDaySelector() {
            const journalType = document.getElementById("journal_type").value;
            const daySelect = document.getElementById("day");
             const MonthSelect = document.getElementById("month");

            // Masquer le sélecteur de jour si le type de journal n'est pas "Journal Journalier"
            if (journalType === "journalier"  ) {
                daySelect.style.display = "inline";
                document.getElementById("month").addEventListener("change", updateDays);
                document.getElementById("year").addEventListener("change", updateDays);
                function updateDays() {
        const year = document.getElementById("year").value;
        const month = document.getElementById("month").value;
        const daysInMonth = new Date(year, month, 0).getDate();

        const daySelect = document.getElementById("day");
        daySelect.innerHTML = ''; // Efface toutes les options actuelles

        for (let day = 1; day <= daysInMonth; day++) {
            const option = document.createElement("option");
            option.value = day;
            option.text = day;
            daySelect.appendChild(option);
            
        }
    }

    // Appeler updateDays une fois pour initialiser les options de jour
    updateDays();
            }else{
                daySelect.style.display = "none";
                
            }
        }

    
        
     


        toggleDaySelector();

    </script>
{% endblock %}