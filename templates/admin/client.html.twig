  {% extends 'include/base-admin.html.twig' %}
{%  block title %}
    Client
{% endblock %}
{% block stylesheets %}
  
{% endblock %}

{% block body %}
    <div class="modal-header text-center">
        <h5 class="modal-title white-text w-100 font-weight-bold py-2">Client</h5>

    </div>
    <div class="grid-edit-btn ">
         <button class="btn btn-primary new">+ Nouveau Client</button>
          <a href="{{ path('export_client') }}" class="btn btn-success">Exporter</a>
    </div>


    <div class="row-table table-content mt-3">
    <form action="{{ path('admin') }}" method="POST" class="search-form mb-2">
        <input type="text" name="search"  placeholder="Rechercher..." value="{{ search }}">
        <button type="submit">Rechercher</button>
    </form>

        <table class="table table-striped" id="example1">
            <thead>
            <tr>
                <th>Code</th>
                <th>Nom</th>
                <th>Prenoms </th>
                <th>Adresse</th>
                <th>Status</th>
                <th>Action</th>
            </tr>
            </thead>
            <tbody>
               
              
             {% for client in pagination %}     
                <tr>
                    <td>{{ client.code }}</td>
                    <td>{{ client.nom }}</td>
                    <td>{{ client.prenom }}</td>
                    <td>{{ client.adresse }}</td>
                    <td>
                        {% if client.coupure == true %}
                            <p class="badge badge-danger">Coupée</p>
                        {% else %}
                            <p class="badge badge-success">Actif</p>

                        {% endif %}
                    </td>
                    <td style="display:flex">
                        <span class="btn btn-info editer" data-id="{{ client.id }}">Modifier</span>
                        <a href="{{ path('client_admin',{'id': client.id }) }}" class="btn btn-success">Voir</a> 
                        {% if client.coupure == true %}
                        <span class="btn btn-success remise" data-id="{{ client.id }}">Remise</span>

                        {% else %}
                            <span class="btn btn-danger couper" data-id="{{ client.id }}">Couper</span>
                        {% endif %}
                    </td>                        
                </tr>
                  
             {% endfor %}
        


            </tbody>
        </table>
    </div>
    <div class="pagination">
    {{ knp_pagination_render(pagination) }}
    </div>
{% endblock %}

{% block javascripts %}

    <script>
       
         $(".editer").on('click' , function(e) {
            $(".loadBody").css("display", "block");
            let id = $(this).data('id');
            let type = "client"
            $.ajax({
                url: "{{ path('add_form_edit_client') }}",
                method: 'POST',
                dataType: 'json',
                data: {
           			id: id,
                    type:type
				},
                success: (data) => {
                    $('.create_body').html(data.form_html);
                    $("#modal_create_body").modal('show');
                    $(".loadBody").css("display", "none");
                },
                error: (e) => {
                    $(".loadBody").css("display", "none");
                    $(".chargementError").css("display", "block");
                }
            }).done(() => {
                $(".loadBody").css("display", "none");
            });
        });
        
        $(".new").on('click' , function(e) {
            $(".loadBody").css("display", "block");
            e.preventDefault();
             let type = "client"
            $.ajax({
                url: "{{ path('add_form_client') }}",
                type: 'post',
                dataType: 'json',
                data: {
                    type:type
				},
                success: (data) => {
                    $('.create_body').html(data.form_html);
                    $("#modal_create_body").modal('show');
                    $(".loadBody").css("display", "none");
                },
                error: (e) => {
                    $(".loadBody").css("display", "none");
                    $(".chargementError").css("display", "block");
                }
            }).done(() => {
                $(".loadBody").css("display", "none");
            });
        });

         $('.couper').on('click', function (e) {
            e.preventDefault();
            var $delete = confirm("Êtes-vous sûr de faire la coupure?");
            if($delete){
                $(".loadBody").css("display", "block");
                var id = $(this).data('id');
                $.ajax({
                    url: "{{ path('coupure_client') }}",
                    type: 'post',
                    data: {
                        id: id,
                    },
                    dataType: "json",
                    success: (data) =>{
                        $(".loadBody").css("display", "none");
                        location.reload();
                    },
                    error: (e) => {
                        $(".loadBody").css("display", "none");
                        $(".chargementError").css("display", "block");
                    }
                }).done(() => {
                    $(".loadBody").css("display", "none");
                });
            }else {
                return false
            }
        });

         $('.remise').on('click', function (e) {
            e.preventDefault();
            var $delete = confirm("Est ce que le droit de remise est payé?");
            if($delete){
                $(".loadBody").css("display", "block");
                var id = $(this).data('id');
                $.ajax({
                    url: "{{ path('remise_client') }}",
                    type: 'post',
                    data: {
                        id: id,
                    },
                    dataType: "json",
                    success: (data) =>{
                        $(".loadBody").css("display", "none");
                        location.reload();
                    },
                    error: (e) => {
                        $(".loadBody").css("display", "none");
                        $(".chargementError").css("display", "block");
                    }
                }).done(() => {
                    $(".loadBody").css("display", "none");
                });
            }else {
                return false
            }
        });




        

    </script>
{% endblock %}