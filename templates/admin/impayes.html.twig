  {% extends 'include/base-admin.html.twig' %}
{%  block title %}
    Recouvrement
{% endblock %}
{% block stylesheets %}
    {{ parent() }}
     <style>
    /* Define your custom styles for pagination here */
    .pagination {
        list-style: none;
        display: flex;
        justify-content: center;
        align-items: center;
        margin: 20px 0;
        padding: 0;
    }

    .pagination li {
        margin: 0 5px;
    }

    .pagination li a,
    .pagination li span {
        display: inline-block;
        padding: 8px 12px;
        border: 1px solid #ccc;
        text-decoration: none;
        color: #333;
    }

    .pagination li.active span {
        background-color: #007bff;
        color: #fff;
    }

    .pagination li.disabled span,
    .pagination li.disabled a {
        color: #aaa;
        pointer-events: none;
    }
    /* Styles for right-aligned search form */
.search-form {
    display: flex;
    justify-content: flex-end; /* Aligns items to the right */
    align-items: center;
}

.search-form input[type="text"],
.search-form button {
    margin-left: 10px;
}

.search-form input[type="text"] {
    padding: 8px;
    border: 1px solid #ccc;
    border-radius: 4px;
    font-size: 14px;
}

.search-form button {
    padding: 8px 12px;
    border: none;
    background-color: #007bff;
    color: #fff;
    border-radius: 4px;
    cursor: pointer;
    font-size: 14px;
}

/* Adjustments for responsiveness if needed */
@media screen and (max-width: 600px) {
    .search-form {
        flex-direction: column;
        justify-content: flex-start; /* Aligns items to the top for smaller screens */
        align-items: flex-end;
    }

    .search-form input[type="text"],
    .search-form button {
        margin-left: 0;
        margin-top: 10px;
    }
}


</style>
{% endblock %}

{% block body %}
    <div class="modal-header text-center">
        <h5 class="modal-title white-text w-100 font-weight-bold py-2">Recouvrement</h5>

    </div>
    <form method="post" id="year-form">
        <label for="year">Sélectionnez une année :</label>
        <select id="year" name="year">
            {% for year in years %}
                <option value="{{ year.year }}" {% if year.year == selectedYear %}selected{% endif %}>{{ year.year }}</option>
            {% endfor %}
        </select>
    </form>

    <div class="col"  style="text-align:right">
        <a href="{{ path('admin_generateExcel') }}"  class="btn btn-success" >Exporter Excel</a>

    </div>

    <div class="row-table table-content mt-3">
     <form action="{{ path('recouvrements_admin') }}" method="POST" class="search-form mb-2">
        <input type="text" name="search"  placeholder="Rechercher..." value="{{ searchQuery }}">
        <button type="submit">Rechercher</button>
    </form>
        <table class="table table-striped" >
            <thead>
            <tr>
                  
                  <th>Code Client</th>
                  <th>Nom Client</th>
                  <th>Prenom Client</th>
                  <th>Mois</th>
                  <th>Montant</th>

            </tr>
            </thead>
            <tbody>
                 {% for releve in releves %}
                    <tr>
                        
                        <td>{{ releve.client.code }}</td>
                        <td>{{ releve.client.nom }} </td>
                        <td>{{ releve.client.prenom }}</td>
                        <td>
                            {% set variable1 = releve.mois %}
                            {% set variable2 = "/" %}
                            {% set variable3 = releve.annee %}
                            {% set resultat = variable1 ~ variable2 ~ variable3 %}
                  

                            {{ resultat }}
                        </td>
                        <td>
                            {% if releve.limite != null %}
                                {% if releve.Consomation <= releve.limite %}
                                        {% set nombre1 = releve.Consomation %}
                                        {% set nombre2 = releve.pu %}
                                        {% set numerator = nombre1 * nombre2 %}
                                        {% set denominator = 5 %} 
                                        {% set percentage1 = (numerator * denominator) / 100 %}
                                        {% set percentage2 = (numerator * 1) / 100 %}
                                        {% set percentage3 = (numerator * 2) / 100 %}
                                        {% if nombre1 > 10 and releve.pus != null  %}
                                        {% set consomation2 = (releve.Consomation - 10) * releve.pus  %}
                                        {% set percentage4 = (consomation2 * 20) / 100 %}

                                        {% set resultatfinale = numerator + 1000 + percentage1 + percentage2 + percentage3 + percentage3 + percentage4 %}
                                        {% else %}
                                        {% set resultatfinale = numerator + 1000 + percentage1 + percentage2 + percentage3 + percentage3 %}

                                        {% endif %}
                                        {{ resultatfinale }}
                                    {% elseif  releve.Consomation > releve.limite and releve.limite != null and releve.pus != null%}
                                    {% set numerator = ((releve.Consomation - releve.limite) * releve.pus) + (releve.limite * releve.pu)  %}
                                        {% set denominator = 5 %} 
                                    {% set percentage1 = (numerator * denominator) / 100 %}
                                    {% set percentage2 = (numerator * 1) / 100 %}
                                    {% set percentage3 = (numerator * 2) / 100 %}
                                    {% if releve.Consomation > 10 and releve.pus != null  %}
                                    {% set consomation2 = (releve.Consomation - 10) * releve.pus  %}
                                    {% set percentage4 = (consomation2 * 20) / 100 %}

                                    {% set resultatfinale = numerator + 1000 + percentage1 + percentage2 + percentage3 + percentage3 + percentage4 %}
                                    {% else %}
                                    {% set resultatfinale = numerator + 1000 + percentage1 + percentage2 + percentage3 + percentage3 %}

                                    {% endif %}
                                    {{ resultatfinale }}
                                    {% endif %}
                                    {% elseif  releve.Consomation != null and releve.pu != null%}
                                      {% set nombre1 = releve.Consomation %}
                                        {% set nombre2 = releve.pu %}
                                        {% set numerator = nombre1 * nombre2 %}
                                        {% set denominator = 5 %} 
                                        {% set percentage1 = (numerator * denominator) / 100 %}
                                        {% set percentage2 = (numerator * 1) / 100 %}
                                        {% set percentage3 = (numerator * 2) / 100 %}
                                        {% if nombre1 > 10 and releve.pus != null  %}
                                        {% set consomation2 = (releve.Consomation - 10) * releve.pus  %}
                                        {% set percentage4 = (consomation2 * 20) / 100 %}

                                        {% set resultatfinale = numerator + 1000 + percentage1 + percentage2 + percentage3 + percentage3 + percentage4 %}
                                        {% else %}
                                        {% set resultatfinale = numerator + 1000 + percentage1 + percentage2 + percentage3 + percentage3 %}

                                        {% endif %}
                                        {{ resultatfinale }}
                                    
                        {% endif %}
                        </td>
                    </tr>
                 {% endfor %}
            </tbody>
        </table>
    </div>
     <div class="pagination">
    {{ knp_pagination_render(releves) }}
    </div>

{% endblock %}

{% block javascripts %}

    <script>
        $(document).ready(function () {
          
             $('#example1').DataTable();

        });
          document.getElementById('year').addEventListener('change', function() {
            // Soumettre le formulaire automatiquement lorsqu'une année est sélectionnée
            document.getElementById('year-form').submit();
        });
     


        

    </script>
{% endblock %}