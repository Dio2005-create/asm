{% extends 'base.html.twig' %}

{% block title %}Admission Login{% endblock %}
{% block body %}
    <form method="post">

        <div class="background-img"></div>
        <div class="body-page" style="margin-top: 9%">
            <div class="container text-center body-content" style="margin-top: 0;">
                <a href="{{ path('homepage') }}"> <img width="200px" src="{{asset('assets/images/logo_suivi.png')}}" alt="logo" id="logo"></a>
                <h3 class="main-title">Admission</h3>
                {% if error %}
                    <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                {% endif %}
                <form role="form" class="form-horizontal">
                    <div class="form-group">
                        <label for="input-id">
                            Identifiant
                        </label>
                        <input id="input-id" type='text' name="username" value="{{ last_username }}" class="form-control">
                    </div>
                    <div class="form-group">
                        <label for="input-id">
                            Mot de passe
                        </label>
                         <input id="password" type='password' name="password" class="form-control" style="display:inline-block;width:329px">
                    <button type="button" onclick="myFunction()" class="btn btn-secondary"  style="position:absolute"><i class="far fa-eye"></i></button>
                    </div>
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                    <button type="submit" class="btn btn-info button-login">
                        Se connecter
                    </button>
                    <div class="form-check ml-3">
                        <div>
                            <div class="checkbox-container">
                                <label class="checkbox-label">
                                    <input type="checkbox">
                                    <span class="checkbox-custom rectangular"></span>
                                </label>
                                <div class="input-title">Rester Connecter</div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>

    </form>
    <!-- Footer -->

        <div class="container mention-legal mt-5">
            Copyright © 2021 MATIPLA
        </div>
  
    <script>
function myFunction() {
        var x = document.getElementById("password");
        
        if (x.type === "password") {
            x.type = "text";
        } else {
            x.type = "password";
        }
    }
    </script>
{% endblock %}
